# ─── Database ───────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (free tier works for development)
DATABASE_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/news-portal?retryWrites=true&w=majority

# ─── Payload CMS ────────────────────────────────────────────────────────────
# Random 32-char secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=REPLACE_WITH_STRONG_SECRET_32_CHARS

# ─── Next.js ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# On Vercel, set this to your production domain: https://yourdomain.com

# ─── Media Storage (Vercel Blob) ────────────────────────────────────────────
# Get from Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ─── Sentry Error Monitoring ────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@xxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxx.ingest.sentry.io/xxxx
SENTRY_AUTH_TOKEN=

# ─── Analytics ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Admin Account (used only for first-run seed script) ────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_ON_FIRST_LOGIN
