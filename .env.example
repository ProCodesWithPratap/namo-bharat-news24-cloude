# ==============================
# DATABASE & CMS
# ==============================
# Railway MongoDB connection string
DATABASE_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db-name>?retryWrites=true&w=majority

# Payload CMS app secret (32+ random chars)
PAYLOAD_SECRET=replace_with_very_strong_secret_32_chars_minimum

# ==============================
# APP URL (CRITICAL)
# ==============================
# ⚠️ Must be exact deployed URL (with https://) on Vercel
NEXT_PUBLIC_SERVER_URL=https://namo-bharat-news24-cloude.vercel.app

# ==============================
# STORAGE
# ==============================
# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ==============================
# AI CHATBOT
# ==============================
# Primary provider (recommended)
ANTHROPIC_API_KEY=

# Fallback provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ==============================
# ANALYTICS & PUBLIC CONTACT
# ==============================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CONTACT_EMAIL=contact@namo-bharat-news24.com
NEXT_PUBLIC_EDITORIAL_EMAIL=editorial@namo-bharat-news24.com

# ==============================
# SEED SCRIPT ONLY
# ==============================
ADMIN_EMAIL=admin@namo-bharat-news24.com
ADMIN_PASSWORD=change_this_before_production

# Public E-paper PDF URL
NEXT_PUBLIC_EPAPER_URL=
